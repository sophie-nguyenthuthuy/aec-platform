{
  "name": "@aec/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "rm -f tsconfig.tsbuildinfo && tsc --noEmit",
    "test": "rm -f tsconfig.tsbuildinfo && tsc --noEmit && vitest run",
    "test:watch": "vitest",
    "test:coverage": "rm -f tsconfig.tsbuildinfo && tsc --noEmit && vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:real-auth": "playwright test --config=playwright.real-auth.config.ts",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@aec/types": "workspace:*",
    "@aec/ui": "workspace:*",
    "@hookform/resolvers": "^3.9.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.100.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.445.0",
    "next": "14.2.35",
    "next-intl": "^3.20.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.74.0",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.7.4",
    "@vitest/coverage-v8": "^2.1.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.4.5",
    "vitest": "^2.1.4"
  }
}
