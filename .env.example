# Database
DATABASE_URL=postgresql+asyncpg://aec:aec@localhost:5432/aec
DATABASE_URL_SYNC=postgresql://aec:aec@localhost:5432/aec

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SUPABASE_JWT_SECRET=replace-me
JWT_ALGORITHM=HS256

# AI — self-hosted OSS LLM via OpenAI-compatible endpoint.
# Default: Ollama on localhost. For GPU production, point LLM_BASE_URL at a
# vLLM/SGLang gateway. No managed-API keys; all models are Apache-2.0 / OSS.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=
LLM_CHAT_MODEL=qwen2.5:7b-instruct
LLM_VISION_MODEL=qwen2.5vl:7b
LLM_EMBEDDING_MODEL=nomic-embed-text
# Production GPU: bump LLM_CHAT_MODEL to qwen2.5:32b-instruct for the full
# reasoning model. 7b keeps the CPU/laptop dev path under ~6 GB RAM.

# Storage
AWS_REGION=ap-southeast-1
S3_BUCKET=aec-platform-files
# Leave blank to use the default AWS provider chain (IAM role, ~/.aws/credentials).
# Set only for static credentials in local dev.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Hybrid retrieval (BM25 sidecar for CodeGuard + Drawbridge Q&A).
# If unreachable, pipelines fall back to pgvector-only dense search.
ELASTICSEARCH_URL=http://localhost:9200

# Drawbridge
# Cross-encoder reranker; leave blank to skip the rerank stage.
DRAWBRIDGE_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# Vision model for title-block OCR during document ingest. Use any OSS
# multimodal model your endpoint serves (qwen2.5vl, llava, internvl, ...).
DRAWBRIDGE_VISION_MODEL=qwen2.5vl:7b

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@aec-platform.vn

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
