{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/docker/worker.arq.Dockerfile"
  },
  "deploy": {
    "startCommand": "arq workers.queue.WorkerSettings",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
