# Vercel production env template for the AEC platform.
#
# Set every variable below in Vercel dashboard → Project → Settings →
# Environment Variables. None of these should live in git.
#
# Scopes:
#   ALL      = Production + Preview + Development
#   PROD     = Production only
#   PROD+PREV = Production + Preview (skip for ephemeral PR previews)

# ===== Supabase (set after Step 1 in deploy/DEPLOY.md) =====
# Project URL — shown in Supabase → Settings → API. Scope: ALL.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Anon / publishable key — safe to ship to browser. Scope: ALL.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...

# Service role key — server-only. Used by routers/admin for cross-tenant
# operations. NEVER set scope to anything client-side. Scope: PROD+PREV.
SUPABASE_SECRET_KEY=sb_secret_...
# Same as NEXT_PUBLIC_SUPABASE_URL but without the public prefix, for
# the FastAPI's JWKS lookup. Scope: PROD+PREV.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# ===== Postgres (Supabase managed) =====
# Async runtime URL — used by every request handler. Use the
# *transaction-mode pooler* URL (port 5432, "Connection pooling →
# Transaction" in Supabase). Scope: PROD+PREV.
DATABASE_URL=postgresql+asyncpg://postgres.YOUR-REF:YOUR-PWD@aws-0-REGION.pooler.supabase.com:5432/postgres
# Sync URL — used only by alembic during the init-supabase.sh script,
# and by AdminSessionFactory at runtime. Use the *direct connection*
# (port 5432, "Direct connection" tab). Pooler doesn't work for DDL.
# Scope: PROD+PREV.
DATABASE_URL_SYNC=postgresql://postgres:YOUR-PWD@db.YOUR-REF.supabase.co:5432/postgres
# Admin async URL for cross-tenant batch jobs. Same as DATABASE_URL is
# fine for the demo (Supabase's `postgres` role is BYPASSRLS by default).
# Scope: PROD+PREV.
DATABASE_URL_ADMIN=postgresql+asyncpg://postgres.YOUR-REF:YOUR-PWD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ===== Redis (Upstash) =====
# TLS connection string (starts with rediss://). Copy from Upstash
# console → Details → Connect → "TLS". Scope: PROD+PREV.
REDIS_URL=rediss://default:YOUR-PWD@YOUR-REGION-redis.upstash.io:6379

# ===== AI keys =====
# Google AI Studio — used for both chat (Gemini 1.5 Flash) and
# embeddings (text-embedding-004). Get one at
# https://aistudio.google.com → "Get API key". Free tier covers a
# generous demo budget (~1500 chat req/day on Flash). Works from
# Vietnam, unlike Anthropic + OpenAI billing. Scope: PROD+PREV.
GOOGLE_API_KEY=AIza...
# Optional — pin a specific Gemini model. Defaults below are sane
# free-tier picks. Scope: PROD+PREV.
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# Legacy — leave blank. Kept on the form for the "switch back" path.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ===== App config =====
# Flips on the strict-secret guard in core.config + JSON log format.
# Scope: PROD.
AEC_ENV=production
# Public origin of the web app. Used to build absolute URLs in emails,
# the assistant's "view in app" links, etc. Set this to your Vercel
# domain (no trailing slash). Scope: PROD.
WEB_BASE_URL=https://YOUR-PROJECT.vercel.app
# CORS allowlist for the FastAPI middleware. JSON array of origins.
# Same as WEB_BASE_URL; the Vercel rewrite path doesn't strictly need
# CORS but the assistant's iframe-embed path does. Scope: PROD.
CORS_ORIGINS=["https://YOUR-PROJECT.vercel.app"]
# Frontend → backend base URL. Leave EMPTY so the browser uses the
# Vercel `/api` rewrite (same-origin, no CORS preflight). Scope: ALL.
NEXT_PUBLIC_API_URL=

# ===== Email (Resend, recommended) =====
# Resend transactional-email backend. When set, the mailer routes
# every notification (RFQ supplier dispatch, codeguard quota
# threshold alerts, ops drift, invitations, daily activity digests,
# weekly client reports) through Resend's API. Resend handles DKIM,
# SPF, bounces, and reputation — no MTA babysitting.
#
# Get a key at https://resend.com (free tier: 3k/mo). Verify your
# sending domain in the Resend dashboard before pointing `RESEND_FROM`
# at it. Scope: PROD+PREV (worker service only — Vercel API doesn't
# send mail directly).
# RESEND_API_KEY=re_...
# RESEND_FROM=AEC Platform <no-reply@aec-platform.vn>
# RESEND_REPLY_TO=support@aec-platform.vn

# ===== Email (SMTP, fallback) =====
# Only used when RESEND_API_KEY is unset. Useful for self-hosted SOE
# customers who require email to stay inside the corporate network.
# STARTTLS on port 587. Scope: PROD+PREV (worker service only).
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.xxx
# EMAIL_FROM=no-reply@aec-platform.vn

# ===== Optional =====
# Sentry DSN — uncomment to wire prod error reporting.
# SENTRY_DSN=https://...@sentry.io/...
# Slow-query alert threshold (ms).
SLOW_QUERY_MS=500
